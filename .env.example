# AWS credentials — never commit real credentials
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# S3 bucket names (populated after terraform apply)
RAW_BUCKET=missing-kids-raw-dev-<account-id>
PROCESSED_BUCKET=missing-kids-processed-dev-<account-id>

# SQS (for scripts/check_dlq.sh)
DLQ_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/missing-kids-dlq-dev

# Lambda
LOG_LEVEL=INFO

# Snowflake connection settings
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
SNOWFLAKE_TABLE_PREFIX=missing_kids
